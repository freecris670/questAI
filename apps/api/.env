# Supabase
# При локальном запуске используйте значения из нижеследующих переменных
# При запуске в Railway используются значения из Railway Variables
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}
SUPABASE_JWT_SECRET=${SUPABASE_JWT_SECRET}

# OpenAI
# При запуске в Railway используется значение из Railway Variables
OPENAI_API_KEY=${OPENAI_API_KEY}

# Приложение
PORT=${PORT:-3001}
FRONTEND_URL=${FRONTEND_URL:-http://localhost:3000}
NODE_ENV=${NODE_ENV:-development}

# Ограничение запросов (Rate Limiting)
RATE_LIMIT_GLOBAL=${RATE_LIMIT_GLOBAL:-100}          # Максимум запросов в минуту на все эндпоинты
RATE_LIMIT_QUEST_MINUTE=${RATE_LIMIT_QUEST_MINUTE:-3}     # Лимит генерации квестов в минуту
RATE_LIMIT_QUEST_HOUR=${RATE_LIMIT_QUEST_HOUR:-20}      # Лимит генерации квестов в час

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=${CLOUDPAYMENTS_PUBLIC_ID:-your-public-id}
CLOUDPAYMENTS_API_SECRET=${CLOUDPAYMENTS_API_SECRET:-your-api-secret}
