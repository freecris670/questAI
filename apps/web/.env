# Переменные окружения для веб-приложения Quest AI
# При запуске в Railway переменные автоматически подтягиваются из Railway Variables

# API URL
NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://questai-api-production.up.railway.app}

# Supabase Public
NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}

# App Config
PORT=${PORT:-3000}
NODE_ENV=${NODE_ENV:-development}

# Analytics and Tracking
NEXT_PUBLIC_GA_ID=${NEXT_PUBLIC_GA_ID}
NEXT_PUBLIC_YM_ID=${NEXT_PUBLIC_YM_ID}

# Feature Flags
NEXT_PUBLIC_ENABLE_PAYMENTS=${NEXT_PUBLIC_ENABLE_PAYMENTS:-false}
NEXT_PUBLIC_ENABLE_SUBSCRIPTION=${NEXT_PUBLIC_ENABLE_SUBSCRIPTION:-false}
