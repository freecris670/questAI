# Этот файл автоматически подтягивает переменные из Railway
# Используйте переменные окружения из Railway для настройки проекта

# Общие переменные подключаются автоматически из Railway
# Специфические переменные для сервисов определены в соответствующих .env файлах

# При локальном запуске используйте: 
# railway run -- [команда]
# или
# railway run --service [имя-сервиса] -- [команда]

NODE_ENV=${NODE_ENV}
